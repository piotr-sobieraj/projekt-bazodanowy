/* =========================================================
   DROP FK
   ========================================================= */

IF OBJECT_ID(N'dbo.Faktura', N'U') IS NOT NULL
AND EXISTS (
    SELECT 1
    FROM sys.foreign_keys
    WHERE name = N'Faktura_Transakcja_FK'
)
BEGIN
    ALTER TABLE dbo.Faktura
        DROP CONSTRAINT Faktura_Transakcja_FK
END
GO

