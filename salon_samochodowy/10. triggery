/**
3. INSTEAD OF trigger — bezpieczne usuwanie klienta

Cel: gdy ktoś próbuje usunąć klienta, który ma oferty, zamiast usunięcia rzucamy błąd.
Jeśli klient nie ma ofert, pozwalamy usunąć.
**/


CREATE OR ALTER TRIGGER dbo.trg_zamiast_usun_klienta
ON dbo.Klient
INSTEAD OF DELETE
AS
BEGIN
    SET NOCOUNT ON;

    IF EXISTS (
        SELECT 1
        FROM deleted d
        JOIN dbo.Oferta o
            ON o.Klient_id_klient = d.id_klient
    )
    BEGIN
        RAISERROR('Nie można usunąć klienta, który ma przypisane oferty.', 16, 1);
        RETURN;
    END;

    DELETE k
    FROM dbo.Klient k
    JOIN deleted d
        ON k.id_klient = d.id_klient;
END;
GO

