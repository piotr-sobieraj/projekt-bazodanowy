CREATE SEQUENCE dbo.seq_klient
    AS INT
    START WITH 10000001
    INCREMENT BY 1;
GO


DECLARE @NextId INT;

SELECT @NextId = ISNULL(MAX(id_klient), 10000000) + 1
FROM dbo.Klient;

DECLARE @sql NVARCHAR(MAX) =
    N'ALTER SEQUENCE dbo.seq_klient RESTART WITH ' + CAST(@NextId AS NVARCHAR(20));

EXEC sp_executesql @sql;
GO





CREATE OR ALTER PROCEDURE dbo.dodaj_klienta
    @nazwa VARCHAR(100),
    @adres VARCHAR(200),
    @nip NUMERIC(10) = NULL,
    @rabat NUMERIC(3,1) = NULL
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    DECLARE @nowe_id_klient NUMERIC(8);

    BEGIN TRY
        BEGIN TRAN;

        IF @nazwa IS NULL OR LTRIM(RTRIM(@nazwa)) = ''
            THROW 50001, 'Nazwa klienta nie może być pusta.', 1;

        IF @adres IS NULL OR LTRIM(RTRIM(@adres)) = ''
            THROW 50002, 'Adres klienta nie może być pusty.', 1;

        IF @rabat IS NOT NULL AND (@rabat < 0 OR @rabat > 99.9)
            THROW 50003, 'Rabat musi być w zakresie 0-99.9.', 1;

        IF @nip IS NOT NULL AND (@nip < 0 OR @nip > 9999999999)
            THROW 50004, 'NIP ma nieprawidłową wartość.', 1;

        SET @nowe_id_klient = NEXT VALUE FOR dbo.seq_klient;

        INSERT INTO dbo.Klient
        (
            id_klient,
            nazwa,
            adres,
            nip,
            rabat
        )
        VALUES
        (
            @nowe_id_klient,
            @nazwa,
            @adres,
            @nip,
            @rabat
        );

        COMMIT;

        SELECT
            @nowe_id_klient AS id_klient,
            @nazwa AS nazwa,
            @adres AS adres,
            @nip AS nip,
            @rabat AS rabat;
    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK;

        THROW;
    END CATCH
END
GO



-- Procedura działająca na dwóch tabelach

CREATE OR ALTER PROCEDURE dbo.dodaj_transakcje
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @id_faktura NUMERIC(8);
    DECLARE @id_towar NUMERIC(10);
    DECLARE @id_samochod INT;
    DECLARE @id_klient NUMERIC(8);
    DECLARE @id_sprzedawca INT;

    SELECT @id_faktura = MAX(id_faktura) + 1
    FROM dbo.Oferta;

    SELECT @id_towar = MAX(id_towar) + 1
    FROM dbo.Oferta;

    SELECT TOP 1 @id_samochod = s.ID_Samochód
    FROM dbo.[Samochód] s
    WHERE NOT EXISTS (
        SELECT 1
        FROM dbo.Oferta o
        WHERE o.[Samochód_ID_Samochód] = s.ID_Samochód
    )
    ORDER BY s.ID_Samochód;

    SELECT TOP 1 @id_klient = k.id_klient
    FROM dbo.Klient k
    WHERE NOT EXISTS (
        SELECT 1
        FROM dbo.Oferta o
        WHERE o.Klient_id_klient = k.id_klient
    )
    ORDER BY k.id_klient;

    SELECT TOP 1 @id_sprzedawca = ID_Sprzedawca
    FROM dbo.Sprzedawca
    ORDER BY ID_Sprzedawca;

    IF @id_samochod IS NULL
    BEGIN
        RAISERROR(N'Brak wolnego samochodu.', 16, 1);
        RETURN;
    END;

    IF @id_klient IS NULL
    BEGIN
        RAISERROR(N'Brak wolnego klienta.', 16, 1);
        RETURN;
    END;

    BEGIN TRANSACTION;

    INSERT INTO dbo.Oferta
    (
        ilosc,
        cena,
        vat,
        rabat,
        id_faktura,
        id_towar,
        [Samochód_ID_Samochód],
        Klient_id_klient,
        Sprzedawca_ID_Sprzedawca
    )
    VALUES
    (
        1.000,
        100000.00,
        23.0,
        0.0,
        @id_faktura,
        @id_towar,
        @id_samochod,
        @id_klient,
        @id_sprzedawca
    );

    INSERT INTO dbo.Transakcja
    (
        Oferta_id_faktura,
        Oferta_id_towar,
        Data
    )
    VALUES
    (
        @id_faktura,
        @id_towar,
        GETDATE()
    );

    COMMIT TRANSACTION;

    SELECT 
        @id_faktura AS id_faktura,
        @id_towar AS id_towar,
        @id_samochod AS id_samochod,
        @id_klient AS id_klient;
END;
GO





