CREATE FUNCTION dbo.sprzedaz_per_sprzedawca
(
    @DataOd DATE,
    @DataDo DATE
)
RETURNS @Wynik TABLE
(
    ID_Sprzedawca INT,
    Imie VARCHAR(30),
    Nazwisko VARCHAR(50),
    SumaSprzedazy DECIMAL(18,2)
)
AS
BEGIN

    INSERT INTO @Wynik
    SELECT
        s.ID_Sprzedawca,
        s.Imie,
        s.Nazwisko,
        SUM(
            o.ilosc * o.cena *
            (1 - ISNULL(o.rabat, 0)/100.0) *
            (1 + o.vat/100.0)
        )
    FROM Sprzedawca s
    JOIN Faktura f
        ON f.id_sprzedawca = s.ID_Sprzedawca
    JOIN Oferta o
        ON o.id_faktura = f.id_faktura
    WHERE f.data BETWEEN @DataOd AND @DataDo
    GROUP BY s.ID_Sprzedawca, s.Imie, s.Nazwisko;

    RETURN;
END
GO


SELECT * FROM dbo.sprzedaz_per_sprzedawca('2025-01-01', '2025-12-31');
